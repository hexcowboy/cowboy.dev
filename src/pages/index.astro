---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="cowboy.dev"
  description="hexcowboy - a fullstack and lead engineer for web3 projects"
>
  <h1 class="text-center font-bold">hexcowboy</h1>
  <p class="text-center">Roaming the frontier of the decentralized web.</p>

  <div>
    <div class="flex justify-between">
      <h2 class="font-bold">direct contact</h2>
      <p>
        (<a href="mailto:hex@cowboy.dev">email</a>, <a
          href="https://discord.com/users/418557177825853443">discord</a
        >)
      </p>
    </div>
    <div class="flex justify-between">
      <h2 class="font-bold">social</h2>
      <p>(<a href="https://twitter.com/hexcowboy">twitter</a>)</p>
    </div>
    <div class="flex justify-between">
      <h2 class="font-bold">software</h2>
      <p>(<a href="https://github.com/hexcowboy">github</a>)</p>
    </div>
  </div>

  <h2 class="font-bold">Skills</h2>
  <ul>
    <li>Typescript</li>
    <ul>
      <li>React</li>
      <li>Nextjs</li>
    </ul>
    <li>Rust</li>
    <li>Golang</li>
    <li>Solidity</li>
  </ul>

